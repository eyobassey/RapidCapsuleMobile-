{
  "testRunner": "jest",
  "runnerConfig": "e2e/jest.config.e2e.js",
  "specs": "e2e",
  "behavior": {
    "init": {
      "reinstallApp": true,
      "exposeGlobals": true
    },
    "cleanup": {
      "shutdownDevice": false
    }
  },
  "apps": {
    "ios.debug": {
      "type": "ios.app",
      "binaryPath": "ios/build/Build/Products/Debug-iphonesimulator/rapidcapsules.app",
      "build": "xcodebuild -workspace ios/rapidcapsules.xcworkspace -scheme rapidcapsules -configuration Debug -sdk iphonesimulator -derivedDataPath ios/build"
    }
  },
  "devices": {
    "ios.simulator": {
      "type": "ios.simulator",
      "device": {
        "type": "iPhone 16"
      }
    }
  },
  "configurations": {
    "ios.debug": {
      "device": "ios.simulator",
      "app": "ios.debug"
    }
  }
}
