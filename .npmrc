# npm-supported options only (strict-peer-dependencies, etc. are pnpm-specific)
save-exact=false

# react-native-nitro-modules is pinned to 0.33.9 (react-native-mmkv + audio-recorder-player
# compatibility). @kingstinct/react-native-healthkit@13.3.1 declares >=0.35 as a peer dep
# but works at runtime with 0.33.9. Allow npm ci to proceed without erroring on this conflict.
legacy-peer-deps=true

# Security
audit=true
fund=false
