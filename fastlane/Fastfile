# encoding: utf-8
# Fix macOS 15 OpenSSL: EC.new can't parse PKCS#8 keys, but PKey.read can
require 'openssl'
require 'fileutils'
require 'tmpdir'

class OpenSSL::PKey::EC
  alias_method :original_initialize, :initialize
  def initialize(*args, &block)
    original_initialize(*args, &block)
  rescue OpenSSL::PKey::ECError => e
    raise unless args.first.is_a?(String)
    pkey = OpenSSL::PKey.read(args.first)
    original_initialize(pkey.to_der)
  end
end

# ─── Constants ────────────────────────────────────────────────────────────────

BUNDLE_ID     = "com.rapidcapsule.mobileapp"
TEAM_ID       = "NS5XW2Q4P8"
IOS_PROJECT   = "ios/RapidCapsules.xcodeproj"
IOS_WORKSPACE = "ios/RapidCapsules.xcworkspace"
IOS_SCHEME    = "RapidCapsules"

# ─── Shared helpers ───────────────────────────────────────────────────────────

def asc_api_key
  app_store_connect_api_key(
    key_id:       ENV["ASC_KEY_ID"]    || "XYZ6XN77NT",
    issuer_id:    ENV["ASC_ISSUER_ID"] || "69a6de93-f1c0-47e3-e053-5b8c7c11a4d1",
    key_filepath: ENV["ASC_KEY_FILEPATH"],  # nil triggers a clear error if unset
    in_house: false
  )
end

def ios_xcargs
  key_id    = ENV["ASC_KEY_ID"]    || "XYZ6XN77NT"
  issuer_id = ENV["ASC_ISSUER_ID"] || "69a6de93-f1c0-47e3-e053-5b8c7c11a4d1"
  key_path  = ENV["ASC_KEY_FILEPATH"]
  "-allowProvisioningUpdates " \
  "-authenticationKeyPath '#{key_path}' " \
  "-authenticationKeyID '#{key_id}' " \
  "-authenticationKeyIssuerID '#{issuer_id}'"
end

# Returns commit subjects only (one per line) since the last git tag.
# Used for changelog generation — we only want the subject line, not the body,
# to avoid body text accidentally matching conventional commit type patterns.
def commit_subjects_since_last_tag
  last_tag = sh("cd .. && git describe --tags --abbrev=0 2>/dev/null || echo ''", log: false).strip
  range    = last_tag.empty? ? "HEAD" : "#{last_tag}..HEAD"
  sh("cd .. && git log #{range} --pretty=format:'%s' --no-merges", log: false).strip
end

# Returns full commit messages (subject + body) since the last git tag.
# Used only by derive_bump_type to detect BREAKING CHANGE footers in the body.
def full_commits_since_last_tag
  last_tag = sh("cd .. && git describe --tags --abbrev=0 2>/dev/null || echo ''", log: false).strip
  range    = last_tag.empty? ? "HEAD" : "#{last_tag}..HEAD"
  sh("cd .. && git log #{range} --pretty=format:'%s%n%b' --no-merges", log: false).strip
end

# Derives the semver bump type from conventional commits since the last tag:
#   BREAKING CHANGE in body / feat! → major
#   feat:                           → minor
#   anything else                   → patch
# Pass override: to force a specific type from the CLI.
def derive_bump_type(override: nil)
  return override if override

  commits = full_commits_since_last_tag
  return 'major' if commits.match?(/^(feat|fix|refactor|chore)!:|^BREAKING CHANGE:/i)
  return 'minor' if commits.match?(/^feat(\(.*?\))?:/)
  'patch'
end

# Strips the conventional commit prefix and capitalises the first word.
# "feat(auth): add biometric login" → "Add biometric login"
def clean_subject(msg)
  msg.sub(/^[a-z]+(\(.*?\))?!?:\s*/, '').capitalize
end

# Truncates text at a whole-line boundary so bullets are never cut mid-sentence.
# Google Play enforces 500 chars on all tracks; Ruby counts Unicode codepoints
# correctly once the file is declared utf-8, matching Play Store's own counting.
def truncate_at_line(text, max_length)
  return text if text.length <= max_length
  truncated  = text[0, max_length]
  last_break = truncated.rindex("\n") || truncated.length
  truncated[0, last_break].strip
end

# ── Beta changelog ─────────────────────────────────────────────────────────────
# Audience : internal testers (TestFlight / Play Store internal track)
# Format   : sectioned with emoji headers — technical detail is appropriate here
# Limits   : TestFlight has no hard limit; Play Store internal caps at 500 chars
# Emojis   : fully supported by both TestFlight and Play Store (UTF-8)
def generate_beta_changelog(max_length: nil)
  subjects = commit_subjects_since_last_tag.split("\n").reject(&:empty?)

  breaking = subjects.select { |c| c.match?(/^[a-z]+(\(.*?\))?!:/) }
  features = subjects.select { |c| c.match?(/^feat(\(.*?\))?:/) && !c.match?(/!:/) }
  fixes    = subjects.select { |c| c.match?(/^fix(\(.*?\))?:/)  && !c.match?(/!:/) }

  sections = []
  sections << "⚠️ Breaking changes:\n"  + breaking.map { |c| "  • #{clean_subject(c)}" }.join("\n") unless breaking.empty?
  sections << "✨ New:\n"               + features.map { |c| "  • #{clean_subject(c)}" }.join("\n") unless features.empty?
  sections << "🐛 Fixed:\n"             + fixes.map    { |c| "  • #{clean_subject(c)}" }.join("\n") unless fixes.empty?

  result = sections.empty? ? "Internal improvements and maintenance." : sections.join("\n\n")
  max_length ? truncate_at_line(result, max_length) : result
end

# ── Release changelog ──────────────────────────────────────────────────────────
# Audience : end users (App Store "What's New" / Play Store production)
# Format   : plain bullet list, no technical prefixes, no emoji — professional tone
# Limits   : App Store 4000 chars; Play Store production 500 chars
# Note     : Apple reviewers read this. Bare "bug fixes" as the sole entry on a
#            major version risks a metadata rejection — use the descriptive fallback.
def generate_release_changelog(max_length: nil)
  subjects = commit_subjects_since_last_tag.split("\n").reject(&:empty?)

  # FIX: use !c.match?(/!:/) instead of [^!]: which incorrectly consumed a char
  # before the colon and caused feat: / fix: (no scope) to never match.
  breaking = subjects.select { |c| c.match?(/^[a-z]+(\(.*?\))?!:/) }
  features = subjects.select { |c| c.match?(/^feat(\(.*?\))?:/) && !c.match?(/!:/) }
  fixes    = subjects.select { |c| c.match?(/^fix(\(.*?\))?:/)  && !c.match?(/!:/) }

  lines = []
  lines += breaking.map { |c| "• #{clean_subject(c)}" }
  lines += features.map { |c| "• #{clean_subject(c)}" }
  lines += fixes.map    { |c| "• #{clean_subject(c)}" }

  result = lines.empty? ? "• Performance and stability improvements." : lines.join("\n")
  max_length ? truncate_at_line(result, max_length) : result
end

# ─── Shared lanes (platform-independent) ──────────────────────────────────────

desc "Lint → type-check → test → audit. Run before any build."
lane :validate do
  sh "cd .. && npm run lint"
  sh "cd .. && npm run type-check"
  sh "cd .. && npm test -- --ci --passWithNoTests"
  # critical only: high-severity transitive vulnerabilities in RN dependency trees
  # would permanently block CI at the 'high' threshold.
  sh "cd .. && npm audit --audit-level=critical"
end

# ─── iOS ──────────────────────────────────────────────────────────────────────

default_platform(:ios)

platform :ios do
  before_all { setup_ci if is_ci }

  # ── Private lanes ─────────────────────────────────────────────────────────

  private_lane :bump_build_number do
    # Rescue handles the first-ever deploy when no build exists on TestFlight yet.
    current = begin
      latest_testflight_build_number(api_key: asc_api_key, app_identifier: BUNDLE_ID)
    rescue
      0
    end
    increment_build_number(xcodeproj: IOS_PROJECT, build_number: current + 1)
  end

  private_lane :configure_signing do
    update_code_signing_settings(
      use_automatic_signing: true,
      path:              IOS_PROJECT,
      team_id:           TEAM_ID,
      bundle_identifier: BUNDLE_ID
    )
  end

  private_lane :build_release_ipa do
    gym(
      workspace:      IOS_WORKSPACE,
      scheme:         IOS_SCHEME,
      configuration:  "Release",
      export_method:  "app-store",
      export_options: { signingStyle: "automatic", teamID: TEAM_ID },
      xcargs:         ios_xcargs
    )
  end

  private_lane :tag_and_push do |options|
    version = get_version_number(xcodeproj: IOS_PROJECT, target: IOS_SCHEME)
    build   = get_build_number(xcodeproj: IOS_PROJECT)
    add_git_tag(tag: "ios/#{options[:prefix]}/v#{version}+#{build}")
    push_git_tags
  end

  # ── Public lanes ──────────────────────────────────────────────────────────

  desc "Bump iOS marketing version. Auto-derives bump type from commits; override with type: patch | minor | major"
  lane :bump_version do |options|
    type = derive_bump_type(override: options[:type])
    UI.message "Bump type: #{type} (derived from commits since last tag)"

    new_version = increment_version_number(xcodeproj: IOS_PROJECT, bump_type: type)
    sh "cd .. && npm version #{new_version} --no-git-tag-version", log: false
    git_commit(
      path:    ["../ios/RapidCapsules.xcodeproj/project.pbxproj", "../package.json"],
      message: "chore(ios): bump version to #{new_version}"
    )
    push_to_git_remote
    UI.success "iOS version bumped to #{new_version}"
  end

  desc "Debug build for Detox E2E"
  lane :build_debug do
    gym(
      workspace:        IOS_WORKSPACE,
      scheme:           IOS_SCHEME,
      configuration:    "Debug",
      export_method:    "development",
      skip_codesigning: true,
      skip_archive:     true,
      silent:           true
    )
  end

  desc "Build and upload to TestFlight with auto-generated release notes"
  lane :beta do
    bump_build_number
    configure_signing
    build_release_ipa
    upload_to_testflight(
      api_key:                           asc_api_key,
      changelog:                         generate_beta_changelog,
      skip_submission:                   true,
      skip_waiting_for_build_processing: true
    )
    tag_and_push(prefix: "beta")
  end

  desc "Build and submit to App Store (production)"
  lane :release do
    bump_build_number
    configure_signing
    build_release_ipa
    deliver(
      api_key:           asc_api_key,
      release_notes:     { "en-US" => generate_release_changelog(max_length: 4000) },
      submit_for_review: false,
      force:             true,
      automatic_release: false
    )
    tag_and_push(prefix: "release")
  end

  desc "Push App Store metadata from fastlane/metadata/ to App Store Connect (no binary upload)"
  lane :metadata do
    deliver(
      api_key:            asc_api_key,
      skip_binary_upload: true,
      skip_screenshots:   true,
      force:              true
    )
  end
end

# ─── Android ──────────────────────────────────────────────────────────────────

platform :android do
  before_all { setup_ci if is_ci }

  # ── Private lanes ─────────────────────────────────────────────────────────

  private_lane :bump_version_code do
    gradle_path = "../android/app/build.gradle"
    contents    = File.read(gradle_path)
    new_code    = contents.match(/versionCode\s+(\d+)/)[1].to_i + 1
    File.write(gradle_path, contents.sub(/versionCode\s+\d+/, "versionCode #{new_code}"))
    new_code
  end

  private_lane :signing_properties do
    {
      "android.injected.signing.store.file"     => ENV["ANDROID_KEYSTORE_PATH"],
      "android.injected.signing.store.password" => ENV["ANDROID_KEYSTORE_PASSWORD"],
      "android.injected.signing.key.alias"      => ENV["ANDROID_KEY_ALIAS"],
      "android.injected.signing.key.password"   => ENV["ANDROID_KEY_PASSWORD"]
    }
  end

  # Writes the internal-track changelog to the path supply auto-discovers:
  # metadata/android/en-US/changelogs/<versionCode>.txt (Play Store: 500 char max)
  private_lane :write_internal_changelog do |options|
    dir = "../fastlane/metadata/android/en-US/changelogs"
    FileUtils.mkdir_p(dir)
    File.write("#{dir}/#{options[:version_code]}.txt", generate_beta_changelog(max_length: 500))
  end

  # Writes the public (production) release notes to a temp file named en-US.txt.
  # supply derives the locale from the filename, so the name must be the locale code.
  # Returns the absolute path for use in whatsnew_paths:.
  private_lane :write_public_changelog do
    dir  = Dir.mktmpdir("rc_whatsnew")
    path = "#{dir}/en-US.txt"
    File.write(path, generate_release_changelog(max_length: 500))
    path
  end

  # ── Public lanes ──────────────────────────────────────────────────────────

  desc "Bump Android versionName. Auto-derives bump type from commits; override with type: patch | minor | major"
  lane :bump_version do |options|
    type = derive_bump_type(override: options[:type])
    UI.message "Bump type: #{type} (derived from commits since last tag)"

    gradle_path = "../android/app/build.gradle"
    current     = File.read(gradle_path).match(/versionName\s+"([^"]+)"/)[1]
    parts       = current.split('.').map(&:to_i)
    new_version = case type
                  when 'major' then "#{parts[0] + 1}.0.0"
                  when 'minor' then "#{parts[0]}.#{parts[1] + 1}.0"
                  when 'patch' then "#{parts[0]}.#{parts[1]}.#{parts[2] + 1}"
                  end

    File.write(gradle_path, File.read(gradle_path).sub(/versionName\s+"[^"]+"/, "versionName \"#{new_version}\""))
    sh "cd .. && npm version #{new_version} --no-git-tag-version", log: false
    git_commit(path: [gradle_path, "../package.json"], message: "chore(android): bump version to #{new_version}")
    push_to_git_remote
    UI.success "Android version bumped to #{new_version}"
  end

  desc "Assemble debug APK for internal QA / Detox"
  lane :build_debug do
    gradle(task: "assembleDebug", project_dir: "android")
  end

  desc "Increment versionCode, build signed bundle, upload to Play Store internal track"
  lane :beta do
    new_code = bump_version_code
    gradle(
      task:        "bundle",
      build_type:  "Release",
      project_dir: "android",
      properties:  signing_properties
    )
    write_internal_changelog(version_code: new_code)
    upload_to_play_store(
      track:                   "internal",
      json_key:                ENV["GOOGLE_PLAY_JSON_KEY"],
      skip_upload_apk:         true,
      skip_upload_images:      true,
      skip_upload_screenshots: true
    )
    version_name = File.read("../android/app/build.gradle").match(/versionName\s+"([^"]+)"/)[1]
    add_git_tag(tag: "android/beta/v#{version_name}+#{new_code}")
    push_git_tags
  end

  desc "Promote internal build to production (10% staged rollout) with user-facing release notes"
  lane :release do
    upload_to_play_store(
      track:                   "internal",
      track_promote_to:        "production",
      rollout:                 "0.1",
      json_key:                ENV["GOOGLE_PLAY_JSON_KEY"],
      whatsnew_paths:          [write_public_changelog],
      skip_upload_apk:         true,
      skip_upload_aab:         true,
      skip_upload_images:      true,
      skip_upload_screenshots: true
    )
  end

  desc "Increase production rollout. Pass percentage:50 or percentage:100"
  lane :rollout do |options|
    percentage = options[:percentage] || UI.user_error!("percentage: is required — e.g. percentage:50")
    upload_to_play_store(
      track:                   "production",
      rollout:                 (percentage.to_f / 100).to_s,
      json_key:                ENV["GOOGLE_PLAY_JSON_KEY"],
      skip_upload_apk:         true,
      skip_upload_aab:         true,
      skip_upload_images:      true,
      skip_upload_screenshots: true
    )
    UI.success "Production rollout updated to #{percentage}%"
  end
end
