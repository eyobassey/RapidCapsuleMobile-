{
  "$schema": "https://raw.githubusercontent.com/expo/eas-cli/main/packages/eas-cli/schema.json",
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "22.11.0"
    },
    "development": {
      "extends": "base",
      "distribution": "internal",
      "channel": "development",
      "ios": { "simulator": true }
    },
    "staging": {
      "extends": "base",
      "distribution": "internal",
      "channel": "staging"
    },
    "production": {
      "extends": "base",
      "channel": "production",
      "autoIncrement": true
    }
  },
  "update": {
    "channel": "production"
  }
}
