# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

project 'RapidCapsules.xcodeproj'

target 'RapidCapsules' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Fix: RNReanimated inherits HERMES_ENABLE_DEBUGGER=1 but not HERMES_V1_ENABLED,
    # causing it to include removed Hermes inspector headers on RN 0.84+ (Hermes V1).
    if ENV['RCT_HERMES_V1_ENABLED'] != '0'
      installer.pods_project.targets.each do |target|
        if target.name == 'RNReanimated'
          target.build_configurations.each do |config|
            defs = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
            unless defs.include?('HERMES_V1_ENABLED=1')
              defs << 'HERMES_V1_ENABLED=1'
            end
          end
        end
      end
    end

  
      # Remove arm64 exclusion for simulators (needed for Apple Silicon Macs)
      installer.pods_project.build_configurations.each do |config|
        config.build_settings.delete('EXCLUDED_ARCHS[sdk=iphonesimulator*]')
      end
      installer.pods_project.targets.each do |target|
        target.build_configurations.each do |config|
          config.build_settings.delete('EXCLUDED_ARCHS[sdk=iphonesimulator*]')
        end
      end
  
    # Suppress deprecation warnings-as-errors for older pods (iOS SDK 26 compat)
    problematic_pods = ['RNAppleHealthKit', 'HtmlToPdf']
    installer.pods_project.targets.each do |target|
      if problematic_pods.include?(target.name)
        target.build_configurations.each do |config|
          config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
          config.build_settings['WARNING_CFLAGS'] ||= ['$(inherited)']
          config.build_settings['WARNING_CFLAGS'] << '-Wno-deprecated-declarations'
          config.build_settings['WARNING_CFLAGS'] << '-Wno-deprecated-implementations'
        end
      end
    end
  end
end
